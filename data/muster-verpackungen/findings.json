  "impactCategories": [
   "profit_overstatement"
  ],
  "calculations": [
   {
    "label": "Unaccrued prior-period cost",
    "expression": "8 next-period invoices",
    "value": 192000,
    "currency": "EUR"
   }
  ],
  "engineStatus": "detected",
  "aiStatus": "confirmed",
  "tribunal": {
   "defense": "Based on the supplied evidence, there is no convincing innocent explanation for the omission of the December 2025 costs in the 2025 closing. The invoices for services and deliveries in December 2025 were all booked in January 2026, and matching goods receipts from December 2025 are present and still open. There is no evidence of these costs being accrued in 2025, nor are there correcting entries, credit notes, or indications of timing or FX differences that could justify the omission. Internal documentation (export protocols, IT completeness confirmations, and the draft financial statements) confirm completeness and that corrections require explicit reversal/bookings, with no discretion for silent omissions. This matches the classic cutoff failure scenario explicitly referenced in journal entry testing planning.",
   "defenseCitations": [
    {
     "docId": "begleitdokumente-fakturajournal-januar-2026-kreditoren",
     "ref": "Fakturajournal_Januar_2026_Kreditoren!r.2",
     "quote": "ER901427;Rechnung;209130;Nord Transport GmbH;15.01.2026;21.12.2025;22000,00;EUR;Frachten Dez 2025"
    },
    {
     "docId": "begleitdokumente-wareneingangsliste-2025",
     "ref": "Wareneingangsliste_2025!r.842",
     "quote": "WE400840;21.12.2025;;209130;Nord Transport GmbH;22000,00;Dez-Lieferung, Rechnung offen"
    }
   ],
   "verdict": "confirmed",
   "reasoning": "The evidence strongly supports the allegation: 8 invoices relating to December 2025 services were all booked in January 2026, with December 2025 goods receipts showing the costs appropriately relate to 2025 but remained open (unmatched). No 2025 entries or accruals exist for these expenses, and there is no indication of offsetting credit notes, timing, or FX differences. Supporting documentation confirms that such omissions require explicit correction, which has not occurred. Thus, EUR 192,000 of 2025 expense was omitted, resulting in profit overstatement. The defense provides no substantive refutation and the evidence for omission is clear and internally consistent."
  }
